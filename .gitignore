# --- Secrets (SEC-06 / AP-12): .env NUNCA versionado. Use .env.example. ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

