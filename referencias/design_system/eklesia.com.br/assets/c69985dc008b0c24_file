				<div class="elementor-element elementor-element-d81cf37 elementor-widget elementor-widget-image" data-id="d81cf37" data-element_type="widget" data-widget_type="image.default">
				<div class="elementor-widget-container">
															<img loading="lazy" decoding="async" width="1024" height="683" src="https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-1024x683.jpg" class="attachment-large size-large wp-image-2334" alt="" srcset="https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-1024x683.jpg 1024w, https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-300x200.jpg 300w, https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-768x512.jpg 768w, https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-1536x1024.jpg 1536w, https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-2048x1365.jpg 2048w, https://eklesia.com.br/wp-content/uploads/2024/06/01-varios-copiar-930x620.jpg 930w" sizes="(max-width: 1024px) 100vw, 1024px" />															</div>
