# =============================================================================
# .env.example — SaaS Igreja
# -----------------------------------------------------------------------------
# Template de variaveis de ambiente. NAO contem secrets reais (SEC-06 / AP-12).
# Copie para `.env` (que esta no .gitignore) e preencha os valores localmente.
# Em producao, as variaveis sao injetadas pelo EasyPanel — nunca commitadas.
# Carregadas no Django via python-decouple.
# =============================================================================

# --- Django core ---
# SECRET_KEY: gere uma chave forte (ex.: `python -c "import secrets; print(secrets.token_urlsafe(50))"`).
SECRET_KEY=changeme-insecure-dev-key-only
DEBUG=True
DJANGO_SETTINGS_MODULE=core.settings.dev
# Hosts/subdominios permitidos. Em dev, cobre *.localhost para multi-tenant.
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# --- Banco de dados (PostgreSQL 15 — SQLite proibido, AP-13) ---
# Coerente com docker-compose.yml e com o DATABASE_URL do CI.
# Para uso fora do Docker, host=localhost. Dentro da rede compose, host=db.
DATABASE_URL=postgres://saas:saas@localhost:5432/saas_igreja

# --- Redis (broker Celery + readiness check — OD-003) ---
REDIS_URL=redis://localhost:6379/0

# --- Sentry (observabilidade — preencher em prod; vazio desativa) ---
SENTRY_DSN=

# --- Email transacional: Brevo free tier via django-anymail (OD-012) ---
# Usado a partir da Sprint 2. Placeholder por enquanto.
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=nao-responda@saasigreja.com

# --- Cloudflare R2 (storage de midia + backups — OD-003a / OD-007) ---
# Usado a partir da Sprint 6. Bucket de midia separado do bucket de backups.
# Endpoint S3-compatible: https://<account_id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_MEDIA=saas-igreja-media
R2_BUCKET_BACKUPS=saas-igreja-backups
R2_ENDPOINT_URL=
